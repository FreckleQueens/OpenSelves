{
	"name": "openselves-client",
	"private": true,
	"type": "module",
	"scripts": {
		"clean": "rm -rf auto-imports.d.ts build .svelte-kit",
		"dev": "vite dev",
		"build": "yarn prepare && vite build && yarn cap sync",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && cp --update=none .env.example .env",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "yarn check && prettier --check . && eslint .",
		"format": "prettier --write . && eslint . --fix",
		"test": "playwright test"
	},
	"packageManager": "yarn@4.13.0",
	"devDependencies": {
		"@playwright/test": "=1.59.1",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/estree": "^1.0.9",
		"@types/humanize-duration": "^3.27.4",
		"@types/is-url": "^1.2.32",
		"@types/node": "^26.0.1",
		"@types/validator": "^13.15.10",
		"drizzle-orm": "1.0.0-rc.3",
		"eslint": "^10.5.0",
		"magic-string": "^0.30.21",
		"playwright": "=1.59.1",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"sass-embedded": "^1.100.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.0"
	},
	"dependencies": {
		"@capacitor/android": "^8.4.1",
		"@capacitor/cli": "^8.4.1",
		"@capacitor/core": "^8.4.1",
		"@paralleldrive/cuid2": "^3.3.0",
		"altcha": "^3.1.0",
		"filesize": "^11.0.17",
		"humanize-duration": "^3.33.2",
		"is-url": "^1.2.4",
		"konsta": "^5.1.0",
		"openselves-common": "workspace:^",
		"openselves-common-ui": "workspace:^",
		"validator": "^13.15.35",
		"zod": "^4.4.3"
	}
}
