{
	"name": "openselves-client",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "yarn prepare && vite build && yarn cap sync",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && cp --update=none .env.example .env",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "yarn check && prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test"
	},
	"packageManager": "yarn@4.13.0",
	"devDependencies": {
		"@capacitor/assets": "^3.0.5",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@iconify-json/f7": "^1.2.2",
		"@iconify-json/heroicons": "^1.2.3",
		"@iconify-json/heroicons-outline": "^1.2.1",
		"@iconify-json/ic": "^1.2.4",
		"@iconify-json/material-symbols": "^1.2.65",
		"@iconify-json/material-symbols-light": "^1.2.66",
		"@iconify-json/mdi": "^1.2.3",
		"@playwright/test": "=1.58.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/humanize-duration": "^3",
		"@types/is-url": "^1",
		"@types/node": "^25.5.2",
		"@types/validator": "^13.15.10",
		"@vitest/browser-playwright": "^4.1.4",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"magic-string": "^0.30.21",
		"playwright": "=1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"sass-embedded": "^1.99.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"unplugin-auto-import": "^21.0.0",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.8",
		"vitest": "^4.1.4",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@capacitor/android": "^8.3.0",
		"@capacitor/cli": "^8.3.0",
		"@capacitor/core": "^8.3.0",
		"@paralleldrive/cuid2": "^3.3.0",
		"@tailwindcss/vite": "^4.2.2",
		"filesize": "^11.0.17",
		"humanize-duration": "^3.33.2",
		"idb": "^8.0.3",
		"is-url": "^1.2.4",
		"konsta": "^5.0.8",
		"openselves-common": "workspace:^",
		"tailwindcss": "^4.2.2",
		"validator": "^13.15.35",
		"zod": "^4.3.6"
	}
}
