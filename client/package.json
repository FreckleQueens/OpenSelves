{
	"name": "openselves-client",
	"private": true,
	"type": "module",
	"scripts": {
		"clean": "rm -rf auto-imports.d.ts build .svelte-kit",
		"dev": "vite dev",
		"build": "yarn prepare && vite build && yarn cap sync",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && cp --update=none .env.example .env",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "yarn check && prettier --check . && eslint .",
		"format": "prettier --write . && eslint . --fix",
		"test": "playwright test"
	},
	"packageManager": "yarn@4.13.0",
	"devDependencies": {
		"@capacitor/assets": "^3.0.5",
		"@eslint/config-helpers": "^0.6.0",
		"@eslint/js": "^10.0.1",
		"@iconify-json/f7": "^1.2.2",
		"@iconify-json/heroicons": "^1.2.3",
		"@iconify-json/heroicons-outline": "^1.2.1",
		"@iconify-json/ic": "^1.2.4",
		"@iconify-json/material-symbols": "^1.2.79",
		"@iconify-json/material-symbols-light": "^1.2.79",
		"@iconify-json/mdi": "^1.2.3",
		"@playwright/test": "=1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/humanize-duration": "^3.27.4",
		"@types/is-url": "^1.2.32",
		"@types/node": "^26.0.0",
		"@types/validator": "^13.15.10",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"magic-string": "^0.30.21",
		"playwright": "=1.59.1",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"sass-embedded": "^1.100.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"unplugin-auto-import": "^21.0.0",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@capacitor/android": "^8.4.1",
		"@capacitor/cli": "^8.4.1",
		"@capacitor/core": "^8.4.1",
		"@paralleldrive/cuid2": "^3.3.0",
		"@tailwindcss/vite": "^4.3.1",
		"altcha": "^3.1.0",
		"filesize": "^11.0.17",
		"humanize-duration": "^3.33.2",
		"idb": "^8.0.3",
		"is-url": "^1.2.4",
		"konsta": "^5.1.0",
		"openselves-common": "workspace:^",
		"openselves-common-ui": "workspace:^",
		"tailwindcss": "^4.3.1",
		"validator": "^13.15.35",
		"zod": "^4.4.3"
	}
}
