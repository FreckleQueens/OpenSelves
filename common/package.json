{
	"name": "openselves-common",
	"scripts": {
		"clean": "rm -rf dist",
		"build": "yarn build:src && yarn build:tests",
		"build:src": "mkdir -p src/generated && cp ../package.json src/generated/rootPackage.json && yarn tsc",
		"build:tests": "cd ../common/test && rm -rf dist && yarn tsc && cd ..",
		"test": "yarn build && node --enable-source-maps --experimental-test-module-mocks --test test/dist/test/**/*.test.js",
		"dev": "yarn build:src --watch",
		"lint": "eslint src/**/*.ts test/*.ts",
		"format": "eslint src/**/*.ts test/*.ts --fix"
	},
	"main": "./dist/index.js",
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./client": "./dist/client/index.js",
		"./schema": "./dist/schema/index.js",
		"./willow": "./dist/willow/index.js",
		"./eslint.config.mjs": "./eslint.config.mjs",
		"./tsconfig.json": "./tsconfig.json"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/node": "^26.1.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"globals": "^17.7.0",
		"prettier": "^3.8.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0"
	},
	"dependencies": {
		"@paralleldrive/cuid2": "^3.3.0"
	}
}
