{
	"extends": "openselves-common/tsconfig.json",
	"compilerOptions": {
		"rootDir": "./src",
		"rootDirs": ["./src"],
		"outDir": "./dist",
		"tsBuildInfoFile": "./dist/.tsbuildinfo",
		"types": ["node"],
		"lib": ["ESNext"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true
	},
	"include": ["./src/**/*"]
}
