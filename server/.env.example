# Example config for OpenSelves-server
# Copy to .env to get started

# Default is "production". Do NOT change this in production.
# Changing this to "development" is only recommanded in development environments.
# This is used to restrict usage of dangerous, destructive commands in production.
#CLI_ENV=production

# Public facing url (without trailing "/")
# Example: PUBLIC_URL=https://api.openselves.org
PUBLIC_URL=http://127.0.0.1:3000

# Port to listen to. The app will always bind to 127.0.0.1:{PORT}
LISTEN_PORT=3000

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings
DATABASE_URL="mysql://openselves:openselves@localhost:3306/openselves"

# Used to run tests. Must NOT be the same as DATABASE_URL. Can be empty in production.
TEST_DB_URL="mysql://openselves:openselves@localhost:3306/openselves_test"

# Needed for CORS. In most cases, specifying the port isn't needed in production.
# A list of allowed domains separated by a comma.
# Example: ALLOWED_ORIGINS=https://openselves.org,http://localhost,capacitor://localhost
# Suggested is for development environment
ALLOWED_ORIGINS=http://127.0.0.1:4173,http://127.0.0.1:5173,http://localhost,capacitor://localhost

# You must change this to a long, securely generated random string. Recommended length is 64 characters
JWT_SECRET=CHANGE_ME

# In seconds. Keep this value low. Must be below REFRESH_TOKEN_DURATION.
# Suggested value is 15 minutes.
ACCESS_TOKEN_DURATION=900

# In seconds. Can be as big as needed. Use -1 for no expiry.
# Example value is 30 days.
REFRESH_TOKEN_DURATION=2592000

# In bits. Don't go under 16.
REFRESH_TOKEN_SIZE=32

# Simple password to prevent anyone from registering.
# This is required for now, but will be made optional in the future when a captcha is implemented.
REGISTRATION_PASSWORD=CHANGE_ME

# Maximum uploaded file size in bytes
# Suggested value is 5MB
MAX_UPLOAD_SIZE=5000000

# Temporary uploaded files storage path
# If not set, uploaded files will be stored in memory (not recommended for >100 users)
# Default is not set
# Example: TMP_UPLOAD_DIR=./tmp_upload
#TMP_UPLOAD_DIR=

# S3-compatible credentials to allow users to upload larger files
# Optional
#S3_REGION=
#S3_ENDPOINT=
#S3_BUCKET=
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
