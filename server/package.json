{
	"name": "openselves-server",
	"description": "",
	"author": "",
	"private": true,
	"license": "AGPL-3.0-only",
	"type": "module",
	"scripts": {
		"build": "yarn build:src && yarn build:tests",
		"build:src": "nest build && cp package.json dist/package.json && cp ../yarn.lock dist/yarn.lock && sed -i '/\"openselves-common\": \"workspace:^\"/c\\\"openselves-common\": \"../../common\",' dist/package.json && cp drizzle.config.ts dist/drizzle.config.ts && cp -r drizzle dist/drizzle",
		"build:tests": "cd test && rm -rf dist && yarn tsc && cd ..",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "concurrently 'mailpit' 'nest start --watch'",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix && eslint \"test/*.ts\" --fix",
		"test": "yarn build:tests && concurrently --success 'command-1' --kill-others 'mailpit' 'node --enable-source-maps --experimental-test-module-mocks --test test/dist/test/**/*.test.js'",
		"test:only": "yarn build:tests && concurrently --success 'command-1' --kill-others 'mailpit' 'node --enable-source-maps --experimental-test-module-mocks --test-only --test test/dist/test/**/*.test.js'",
		"db:generate": "yarn drizzle-kit generate",
		"db:migrate": "yarn drizzle-kit migrate",
		"db:migrate:test": "yarn drizzle-kit migrate --config ./drizzle-test.config.ts",
		"dev": "yarn build && yarn start:dev",
		"dev:seed": "yarn build && node ./dist/auth/db/seed.js",
		"package": "yarn build && node --build-sea sea-config.json"
	},
	"packageManager": "yarn@4.13.0",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1073.0",
		"@inquirer/prompts": "^8.5.2",
		"@nestjs/cache-manager": "^3.1.3",
		"@nestjs/common": "^11.1.27",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.27",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/platform-express": "^11.1.27",
		"@nestjs/schedule": "^6.1.3",
		"@nestjs/throttler": "^6.5.0",
		"@paralleldrive/cuid2": "^3.3.0",
		"altcha-lib": "^2.2.0",
		"argon2": "^0.44.0",
		"cache-manager": "^7.2.8",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"commander": "^15.0.0",
		"cookie-parser": "^1.4.7",
		"drizzle-orm": "1.0.0-rc.3",
		"ipaddr.js": "^2.4.0",
		"joi": "^18.2.3",
		"openselves-common": "workspace:^",
		"postgres": "^3.4.9",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@nestjs/cli": "^11.0.23",
		"@nestjs/schematics": "^11.1.0",
		"@nestjs/testing": "^11.1.27",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/bun": "^1.3.14",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.6",
		"@types/multer": "^2.1.0",
		"@types/node": "^26.0.0",
		"@types/supertest": "^7.2.0",
		"bun": "^1.3.14",
		"concurrently": "^10.0.3",
		"drizzle-kit": "1.0.0-rc.3",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"globals": "^17.6.0",
		"prettier": "^3.8.4",
		"source-map-support": "^0.5.21",
		"supertest": "^7.2.2",
		"ts-loader": "^9.6.1",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1"
	}
}
